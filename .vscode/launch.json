{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run Extension (Insiders)",
      "type": "node",
      "request": "attach",
      "port": 9333,
      "timeout": 30000,
      "continueOnAttach": true,
      "skipFiles": [
        "<node_internals>/**"
      ],
      "outFiles": [
        "${workspaceFolder}/out/**/*.js"
      ],
      "preLaunchTask": "Launch Extension Host (Insiders)"
    },
    {
      "name": "Run Extension (Stable)",
      "type": "node",
      "request": "attach",
      "port": 9334,
      "timeout": 30000,
      "continueOnAttach": true,
      "skipFiles": [
        "<node_internals>/**"
      ],
      "outFiles": [
        "${workspaceFolder}/out/**/*.js"
      ],
      "preLaunchTask": "Launch Extension Host (Stable)"
    }
  ]
}
